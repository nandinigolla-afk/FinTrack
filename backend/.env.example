# MongoDB connection string (Atlas or local)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/fintrack?retryWrites=true&w=majority

# JWT secret - replace with a long random string in production
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Server
PORT=5000
CLIENT_URL=http://localhost:5173
NODE_ENV=development
